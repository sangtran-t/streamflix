# StreamFlix configuration & secrets matrix (docs/RUNBOOK.md, resolves review C1).
#
# Copy to the repo root as `.env`:  cp infra/.env.example .env
# Compose reads the root `.env` for interpolation; host tooling (prisma/seed) reads
# DATABASE_URL / REDIS_ADDR below.
#
# NEVER commit a real `.env`. These are dev placeholders only — change every secret
# before any non-local use. SIGNING_SECRET is ONE secret shared by api + edge and
# must be rotated as a pair.

# ----------------------------------------------------------------------------
# Postgres
# ----------------------------------------------------------------------------
POSTGRES_USER=streamflix
POSTGRES_PASSWORD=streamflix_dev_pw
POSTGRES_DB=streamflix

# Host-side connection string used by `prisma migrate` / `seed` run from your
# machine (postgres is published on localhost:5432). Inside compose, services get
# a postgres:5432 URL built from the vars above (see docker-compose.yml).
DATABASE_URL=postgresql://streamflix:streamflix_dev_pw@localhost:5432/streamflix?schema=public

# ----------------------------------------------------------------------------
# Redis  (host-side value; compose overrides services to redis:6379)
# ----------------------------------------------------------------------------
REDIS_ADDR=localhost:6379

# ----------------------------------------------------------------------------
# MinIO / S3-compatible object storage
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=streamflix
MINIO_ROOT_PASSWORD=streamflix_dev_secret
S3_BUCKET=streamflix-media
# Host-side endpoint; compose overrides services to http://minio:9000
S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_ENDPOINT: used to generate pre-signed PUT URLs sent to the browser.
# In Docker Compose the api container uses the internal minio:9000 for S3_ENDPOINT,
# but the browser needs localhost:9000 (published port). Set via docker-compose.yml.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_KEY=streamflix
S3_SECRET=streamflix_dev_secret

# ----------------------------------------------------------------------------
# Shared HMAC signing secret for playback cookies — api + edge, rotate together
# (docs/COMMUNICATION.md §4).
# ----------------------------------------------------------------------------
SIGNING_SECRET=dev-signing-secret-change-me

# ----------------------------------------------------------------------------
# JWT auth secrets (used from Phase 3)
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# ----------------------------------------------------------------------------
# Playback URL bases issued by the api (docs/RUNBOOK.md config matrix)
# Behind the single-origin dev proxy the edge is reachable at /hls.
# ----------------------------------------------------------------------------
EDGE_BASE=http://localhost:8080/hls
CDN_BASE=

# ----------------------------------------------------------------------------
# Worker tuning (used from Phase 2)
# ----------------------------------------------------------------------------
TRANSCODE_CONCURRENCY=2
JOB_TIMEOUT_SECONDS=1800
